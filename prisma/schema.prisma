// Prisma schema voor Starterskalender
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// @deprecated — vervangen door het RBAC v2 systeem (Role / Permission / UserRoleAssignment).
// Blijft 2 weken staan als veiligheidsnet en audit-trail. Verwijderen nadat cutover stabiel is.
enum LegacyRole {
  HR_ADMIN
  ENTITY_EDITOR
  ENTITY_VIEWER
  GLOBAL_VIEWER
  NONE
}

enum NotificationType {
  WEEKLY_REMINDER // 1 week voor opstart
  MONTHLY_SUMMARY // Maandelijkse samenvatting
  QUARTERLY_SUMMARY // Kwartaal samenvatting
  YEARLY_SUMMARY // Jaarlijks overzicht
}

enum IdentityProvider {
  MICROSOFT
  MANUAL
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TaskType {
  IT_SETUP // IT-gerelateerde taken (email, telefoon, accounts)
  HR_ADMIN // HR administratie (contract, badges)
  FACILITIES // Facilities (werkplek, parkeerplaats)
  MANAGER_ACTION // Manager acties (welkomstgesprek, intro)
  CUSTOM // Custom taken
  MARKETING_PHOTO // Headshot nemen op startersdag
  MARKETING_EDIT // Foto's bewerken (3 varianten)
  MARKETING_UTM // UTM-code aanmaken voor vCard
  MARKETING_VCARD // vCard aanmaken
  MARKETING_VISITEKAARTJE // Visitekaartjes bestellen
  MARKETING_BADGE // Badge bestellen
  MARKETING_NFC // SIMA NFC badge bestellen
  MARKETING_SIGNATURE // Emailhandtekening aanmaken (fase 2)
}

enum ScheduleType {
  OFFSET_FROM_START // Standaard: dueDate = startDate + daysUntilDue
  ON_START_DATE // Gepland op startersdag zelf (+ O365 event)
  AFTER_DEPENDENCIES // Zodra alle dependencies DONE zijn
}

enum TaskStatus {
  PENDING // Nog niet gestart
  IN_PROGRESS // Bezig
  BLOCKED // Geblokkeerd (wacht op iets/iemand)
  COMPLETED // Voltooid
  CANCELLED // Geannuleerd
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationChannelType {
  IN_APP // In-app notificatie (bell icon)
  EMAIL // Email notificatie
  BOTH // Beide
}

enum StarterType {
  ONBOARDING // Nieuwe medewerker (instroom)
  OFFBOARDING // Vertrekkende medewerker (uitstroom)
  MIGRATION // Interne mutatie tussen entiteiten
}

enum SigningMethod {
  SES // Simple Electronic Signature (click-to-sign)
  QES // Qualified Electronic Signature (Itsme)
}

enum DocumentStatus {
  PENDING // Wacht op ondertekening
  SIGNED // Ondertekend
  EXPIRED // Verlopen (deadline overschreden)
  CANCELLED // Geannuleerd
}

enum MaterialStatus {
  PENDING // Nieuw — actie nodig
  IN_STOCK // Op voorraad — klaar om te reserveren
  ORDERED // Besteld bij leverancier
  RECEIVED // Ontvangen — klaar om te reserveren
  RESERVED // Gereserveerd voor de starter (eindstatus)
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  password         String? // Optional: legacy auth only
  name             String?
  legacyRole       LegacyRole       @default(NONE) @map("role") // @deprecated — migratiepad, behouden voor fallback na RBAC v2 cutover
  identityProvider IdentityProvider @default(MANUAL)
  status           UserStatus       @default(INVITED)

  locale            String   @default("nl") // UI language: "nl" or "fr"
  legacyPermissions String[] @default([]) @map("permissions") // @deprecated — vervangen door UserRoleAssignment

  // Azure AD / Entra ID fields
  tenantId String? // Azure AD tenant ID (tid claim)
  oid      String? // Azure AD object ID (oid claim)

  // RBAC v2
  roleAssignments UserRoleAssignment[]

  memberships             Membership[]
  notificationPreferences NotificationPreference[]
  twoFASecret             String? // TOTP secret voor 2FA
  twoFAEnabled            Boolean                  @default(false)
  bookings                Booking[]
  assignedTasks           Task[]                   @relation("TaskAssignee") // Taken toegewezen aan deze user
  createdTasks            Task[]                   @relation("TaskCreator") // Taken aangemaakt door deze user
  completedTasks          Task[]                   @relation("TaskCompleter") // Taken voltooid door deze user
  taskAssignments         TaskAssignment[]         @relation("TaskAssignmentUser") // Task assignments voor deze user
  notifications           Notification[] // In-app notificaties voor deze user
  auditLogs               AuditLog[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  lastLoginAt             DateTime? // Tijdstip van laatste succesvolle login

  @@index([email])
  @@index([tenantId])
  @@index([oid])
  @@index([status])
  @@index([identityProvider])
}

model Entity {
  id                      String                   @id @default(cuid())
  name                    String                   @unique
  colorHex                String // Kleur voor badges/kaartjes
  isActive                Boolean                  @default(true)
  notifyEmails            String[] // Array van e-mailadressen voor reminders (legacy)
  memberships             Membership[]
  starters                Starter[]                @relation("StarterEntity")
  migrationsFrom          Starter[]                @relation("StarterFromEntity")
  jobRoles                JobRole[]
  blockedPeriods          BlockedPeriod[]
  notificationPreferences NotificationPreference[]
  tasks                   Task[] // Taken gekoppeld aan deze entiteit
  taskAssignments         TaskAssignment[] // Taak verantwoordelijken voor deze entiteit
  signatureTemplate       SignatureTemplate? // Email signature template voor deze entiteit
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([isActive])
}

// @deprecated — vervangen door UserRoleAssignment.entityIds in RBAC v2.
// Blijft 2 weken staan als fallback, daarna droppen.
model Membership {
  id       String  @id @default(cuid())
  userId   String
  entityId String
  canEdit  Boolean @default(false) // false = viewer, true = editor
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity   Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
}

// ─────────────────────────────────────────────────────────────────────────────
// RBAC v2 — Granulaire rechten met beheerbare rollen
// ─────────────────────────────────────────────────────────────────────────────
// Permission: catalogus van alle permission-keys die in de app gecheckt worden.
// Keys volgen het patroon "<resource>:<action>[:<field>]" (bv. "starters:read",
// "starters:read:salary", "admin:roles:manage"). Wordt geseed door de app zelf
// (lib/authz-registry.ts is de source of truth) — admins kennen ze toe aan
// rollen, maar maken geen nieuwe keys aan.
model Permission {
  key          String  @id
  description  String?
  category     String // "starters" | "tasks" | "materials" | "admin" | "users" | "reporting" | …
  isFieldLevel Boolean @default(false) // UI-hint: toon apart onder "veld-permissies"

  roles RolePermission[]

  @@index([category])
}

// Role: globaal gedefinieerde rechtengroep. Wordt toegekend aan users via
// UserRoleAssignment met optionele entity-scope.
model Role {
  id                String   @id @default(cuid())
  key               String   @unique // "hr-admin", "marketing-operator", …
  name              String // Label voor UI (Nederlands)
  description       String?
  isSystem          Boolean  @default(false) // seeded, niet verwijderbaar (permissies wel bewerkbaar)
  bypassEntityScope Boolean  @default(false) // HR-admin stijl: toekenning geldt voor alle entiteiten, los van entityIds
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  permissions RolePermission[]
  assignments UserRoleAssignment[]
}

model RolePermission {
  roleId        String
  permissionKey String
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([roleId, permissionKey])
  @@index([permissionKey])
}

// UserRoleAssignment: toekenning van een rol aan een user met entity-scope.
// - entityIds: []   → toekenning geldt voor alle entiteiten (globaal)
// - entityIds: [x]  → toekenning geldt enkel voor entiteit x
// - bypassEntityScope op rol trumpt deze scope altijd.
model UserRoleAssignment {
  id          String    @id @default(cuid())
  userId      String
  roleId      String
  entityIds   String[]  @default([])
  grantedAt   DateTime  @default(now())
  grantedById String?
  expiresAt   DateTime? // fase 2: tijdelijke toegang

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId]) // 1 toekenning per (user, rol); scope in entityIds
  @@index([userId])
  @@index([roleId])
  @@index([expiresAt])
}

model Starter {
  id                String      @id @default(cuid())
  type              StarterType @default(ONBOARDING)
  entityId          String?
  entity            Entity?     @relation("StarterEntity", fields: [entityId], references: [id], onDelete: SetNull)
  fromEntityId      String? // Bron-entiteit (bij migratie)
  fromEntity        Entity?     @relation("StarterFromEntity", fields: [fromEntityId], references: [id], onDelete: SetNull)
  fromRoleTitle     String? // Bron-functie (bij migratie)
  firstName         String
  lastName          String
  language          String      @default("NL")
  region            String?
  roleTitle         String?
  via               String? // Via (dropdown)
  notes             String?     @db.Text // Extra info
  phoneNumber       String? // Telefoonnummer (optioneel, kan later toegevoegd)
  desiredEmail      String? // Gewenst mailadres
  contractSignedOn  DateTime?   @default(now()) // Datum waarop contract getekend is (tijdelijk nullable voor migratie)
  startDate         DateTime? // Startdatum (onboarding) of vertrekdatum (offboarding) - null bij pending boarding
  weekNumber        Int? // Weeknummer (afgeleid, Monday-first)
  year              Int? // Jaar - null bij pending boarding
  isPendingBoarding Boolean     @default(false) // Startdatum nog niet gekend
  isCancelled       Boolean     @default(false) // Of de starter is geannuleerd
  cancelledAt       DateTime? // Wanneer geannuleerd
  cancelledBy       String? // User ID die annuleerde
  cancelReason      String?     @db.Text // Reden van annulering

  // Ervaring velden (relevant voor onboarding)
  hasExperience    Boolean   @default(false) // Heeft de starter relevante werkervaring?
  experienceSince  DateTime? // Startdatum van ervaring (om duur te berekenen)
  experienceRole   String? // Functie waarin ervaring opgedaan
  experienceEntity String? // Entiteit/bedrijf waar ervaring opgedaan (vrij veld)

  // Gevoelige HR-velden — beschermd via RBAC v2 field-level permissies.
  // Lezen/schrijven vereist `starters:read:salary` resp. `starters:read:bankaccount`.
  salary         Decimal? @db.Decimal(10, 2) // Bruto maandsalaris (EUR)
  salaryCurrency String?  @default("EUR")
  bankAccount    String? // IBAN / rekeningnummer

  createdBy        String? // User ID die het aanmaakte
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  starterMaterials StarterMaterial[] // Materiaal toegewezen aan deze starter
  tasks            Task[] // Taken gekoppeld aan deze starter
  documents        StarterDocument[] // Documenten voor ondertekening

  @@index([type])
  @@index([year, startDate])
  @@index([entityId, year])
  @@index([fromEntityId])
  @@index([weekNumber, year])
  @@index([isCancelled])
  @@index([isPendingBoarding])
}

model JobRole {
  id             String            @id @default(cuid())
  entityId       String
  entity         Entity            @relation(fields: [entityId], references: [id], onDelete: Cascade)
  title          String // Functietitel (bv. "Senior Developer")
  description    String?           @db.Text // Optionele beschrijving
  isActive       Boolean           @default(true)
  order          Int               @default(0) // Sorteervolgorde
  blockedPeriods BlockedPeriod[]
  materials      JobRoleMaterial[] // Materiaal gekoppeld aan deze functie
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([entityId, title])
  @@index([entityId, isActive])
  @@index([entityId, order])
}

model BlockedPeriod {
  id        String   @id @default(cuid())
  entityId  String
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  jobRoleId String? // Optioneel: specifieke functie blokkeren (null = alle functies)
  jobRole   JobRole? @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  startDate DateTime // Begin van geblokkeerde periode
  endDate   DateTime // Einde van geblokkeerde periode
  reason    String?  @db.Text // Reden voor blokkade
  isActive  Boolean  @default(true)
  createdBy String? // User ID die blokkade aanmaakte
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityId, isActive])
  @@index([jobRoleId, isActive])
  @@index([startDate, endDate])
}

model AllowedTenant {
  id         String   @id @default(cuid())
  tenantId   String   @unique // Azure AD Tenant ID
  tenantName String // Organisatie naam voor display
  domain     String? // Primary domain (optioneel, bijv. "company.com")
  isActive   Boolean  @default(true)
  notes      String?  @db.Text // Admin notities
  createdBy  String? // User ID die het toevoegde
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, isActive])
  @@index([isActive])
}

model Material {
  id               String            @id @default(cuid())
  name             String            @unique // Materiaalnaam (bv. "Laptop", "Telefoon", "Badge")
  description      String?           @db.Text // Optionele beschrijving
  category         String? // Categorie (bv. "Hardware", "Software", "Toegang")
  isActive         Boolean           @default(true)
  order            Int               @default(0) // Sorteervolgorde
  jobRoles         JobRoleMaterial[] // Functies die dit materiaal nodig hebben
  starterMaterials StarterMaterial[] // Starters aan wie dit materiaal is toegewezen
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([isActive])
  @@index([category, isActive])
  @@index([order])
}

model JobRoleMaterial {
  id         String   @id @default(cuid())
  jobRoleId  String
  jobRole    JobRole  @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  isRequired Boolean  @default(true) // Of het materiaal verplicht is voor deze functie
  notes      String?  @db.Text // Extra notities (bv. "Alleen voor senior niveau")
  createdAt  DateTime @default(now())

  @@unique([jobRoleId, materialId])
  @@index([jobRoleId])
  @@index([materialId])
}

model StarterMaterial {
  id                   String         @id @default(cuid())
  starterId            String
  starter              Starter        @relation(fields: [starterId], references: [id], onDelete: Cascade)
  materialId           String
  material             Material       @relation(fields: [materialId], references: [id], onDelete: Cascade)
  status               MaterialStatus @default(PENDING)
  isProvided           Boolean        @default(false) // Legacy — true wanneer status = RESERVED
  providedAt           DateTime?
  providedBy           String?
  orderedAt            DateTime?
  expectedDeliveryDate DateTime?
  receivedAt           DateTime?
  reservedAt           DateTime?
  reservedBy           String?
  notes                String?        @db.Text
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([starterId, materialId])
  @@index([starterId])
  @@index([materialId])
  @@index([status])
}

// Notificatie voorkeuren per gebruiker per entiteit
model NotificationPreference {
  id       String @id @default(cuid())
  userId   String
  entityId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity   Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  // Notificatie toggles per type
  weeklyReminder   Boolean @default(true) // 1 week voor opstart
  monthlySummary   Boolean @default(true) // Maandelijkse samenvatting
  quarterlySummary Boolean @default(true) // Kwartaal samenvatting
  yearlySummary    Boolean @default(true) // Jaarlijks overzicht

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
}

// Email templates voor notificaties
model EmailTemplate {
  id       String           @id @default(cuid())
  type     NotificationType @unique // WEEKLY_REMINDER, MONTHLY_SUMMARY, etc.
  subject  String // Email onderwerp (met variabelen)
  body     String           @db.Text // Email body HTML (met variabelen)
  isActive Boolean          @default(true)

  // Beschrijving van beschikbare variabelen
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // User ID die template aanmaakte
  updatedBy String? // User ID die template laatst wijzigde

  @@index([type])
  @@index([isActive])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  target    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// System settings voor branding en configuratie
model SystemSettings {
  id    String  @id @default(cuid())
  key   String  @unique // bv. "logo_url", "company_name"
  value String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String? // User ID die instelling laatst wijzigde

  @@index([key])
}

// Task Management System

// Task Templates - Voor automatische taak creatie
model TaskTemplate {
  id           String       @id @default(cuid())
  type         TaskType // Type taak
  title        String // Taak titel (met variabelen: {{starterName}}, {{entityName}})
  description  String?      @db.Text // Beschrijving (met variabelen)
  priority     TaskPriority @default(MEDIUM)
  daysUntilDue Int          @default(7) // Aantal dagen vanaf startDate tot deadline
  isActive     Boolean      @default(true)
  autoAssign   Boolean      @default(true) // Automatisch toewijzen bij nieuwe starter

  // Optionele filters - wanneer moet deze template worden toegepast?
  forEntityIds           String[] // Lege array = alle entiteiten
  forJobRoleTitles       String[] // Lege array = alle functies (tenzij requireExplicitJobRole = true)
  requireExplicitJobRole Boolean      @default(false) // Als true: enkel toepassen bij expliciete match in forJobRoleTitles; lege lijst = geen enkele functie
  forStarterType         StarterType? // null = beide types, anders alleen voor dit type

  // Dependencies & scheduling (marketing workflow + generiek)
  dependsOnTemplateIds String[]     @default([]) // AND-gate: concrete dep-templates
  scheduleType         ScheduleType @default(OFFSET_FROM_START)
  addToCalendar        Boolean      @default(false) // O365 event aanmaken voor assignee
  uploadFolder         String? // submap in SharePoint (bv. "marketing")
  expectedOutputs      Json? // bv. ["forms-photo","linkedin","signature"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // User ID

  @@index([type, isActive])
  @@index([autoAssign, isActive])
  @@index([forStarterType])
}

// Taken
model Task {
  id          String       @id @default(cuid())
  type        TaskType // Type taak
  title       String // Taak titel
  description String?      @db.Text // Beschrijving
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)

  // Koppelingen
  starterId String? // Optioneel gekoppeld aan starter
  starter   Starter? @relation(fields: [starterId], references: [id], onDelete: Cascade)
  entityId  String? // Optioneel gekoppeld aan entiteit
  entity    Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)

  // Toewijzing
  assignedToId String? // User ID van verantwoordelijke
  assignedTo   User?     @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedAt   DateTime? // Wanneer toegewezen

  // Deadlines
  dueDate DateTime? // Deadline

  // Voltooiing
  completedAt     DateTime?
  completedById   String?
  completedBy     User?     @relation("TaskCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  completionNotes String?   @db.Text // Notities bij voltooiing

  // Blokkering
  blockedReason String? @db.Text // Waarom geblokkeerd

  // Metadata
  createdById String?
  createdBy   User?    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Template tracking
  templateId String? // Als aangemaakt vanuit template

  // Dependencies & scheduling
  dependsOnTaskIds String[]  @default([]) // AND-gate: concrete Task IDs
  scheduledFor     DateTime? // Voor ON_START_DATE taken (tijdstip event)
  o365EventId      String? // MS Graph event reference (bij addToCalendar)

  // Marketing uploads (foto-varianten, emailhandtekening, etc.)
  uploads         StarterTaskUpload[]
  reassignHistory TaskReassignment[]

  // Document koppeling
  document StarterDocument?

  @@index([status, assignedToId])
  @@index([starterId, status])
  @@index([entityId, status])
  @@index([assignedToId, dueDate])
  @@index([type, status])
  @@index([dueDate])
}

// Taak verantwoordelijken per entiteit en taak type
model TaskAssignment {
  id           String   @id @default(cuid())
  entityId     String? // null = global default voor alle entiteiten
  entity       Entity?  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  taskType     TaskType // Type taak
  assignedToId String // User ID van verantwoordelijke
  assignedTo   User     @relation("TaskAssignmentUser", fields: [assignedToId], references: [id], onDelete: Cascade)

  // Notificatie instellingen
  notifyChannel NotificationChannelType @default(BOTH)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // User ID die assignment aanmaakte

  @@unique([entityId, taskType]) // Per entiteit+type slechts 1 verantwoordelijke
  @@index([entityId, taskType])
  @@index([assignedToId])
}

// Uploads per taak (foto-varianten, handtekening, etc.) — opgeslagen in SharePoint
model StarterTaskUpload {
  id             String   @id @default(cuid())
  taskId         String
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName       String
  sharePointPath String // Volledig pad in SharePoint
  mimeType       String?
  sizeBytes      Int?
  variant        String? // bv. "forms-photo", "linkedin", "signature", "headshot-raw"
  uploadedById   String?
  uploadedAt     DateTime @default(now())

  @@index([taskId])
  @@index([variant])
}

// Log van taak-hertoewijzingen
model TaskReassignment {
  id             String   @id @default(cuid())
  taskId         String
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromUserId     String?
  toUserId       String?
  reassignedById String?
  reason         String?  @db.Text
  reassignedAt   DateTime @default(now())

  @@index([taskId, reassignedAt])
}

// In-app notificaties
model Notification {
  id     String @id @default(cuid())
  userId String // Ontvanger
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String // TASK_ASSIGNED, TASK_DUE_SOON, TASK_COMPLETED, etc.
  title   String // Notificatie titel
  message String @db.Text // Notificatie bericht

  // Koppelingen (optioneel)
  taskId    String? // Gekoppeld aan taak
  starterId String? // Gekoppeld aan starter

  // Link naar relevante pagina
  linkUrl String? // bv. "/taken/abc123"

  // Status
  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([taskId])
}

// Room booking models
model Room {
  id              String    @id @default(cuid())
  name            String
  capacity        Int
  location        String?
  msResourceEmail String? // Microsoft resource mailbox email (bijv. room-1@domain)
  hourlyRateCents Int       @default(0) // Voor verhuur
  active          Boolean   @default(true)
  bookings        Booking[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active])
  @@index([msResourceEmail])
}

model Booking {
  id            String        @id @default(cuid())
  roomId        String
  room          Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalEmail String?
  title         String
  description   String?
  start         DateTime
  end           DateTime
  status        BookingStatus @default(PENDING)
  msEventId     String? // Graph event id in resource mailbox
  msICalUid     String? // Voor idempotentie
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdBy     String? // User ID die het aanmaakte
  updatedBy     String? // User ID die laatst wijzigde

  @@index([roomId, start, end])
  @@index([userId])
  @@index([status])
  @@index([msEventId])
}

// Email verzendingen loggen (voor cron jobs en task notifications)
model EmailLog {
  id              String           @id @default(cuid())
  type            NotificationType // WEEKLY_REMINDER, MONTHLY_SUMMARY, etc.
  recipient       String // Email adres van ontvanger
  recipientUserId String? // User ID als bekend
  subject         String // Email onderwerp
  startersCount   Int? // Aantal starters in email (indien van toepassing)
  entities        String[] // Entiteit namen (indien van toepassing)
  status          String           @default("SENT") // SENT, FAILED, BOUNCED
  errorMessage    String?          @db.Text // Foutmelding indien gefaald
  metadata        Json? // Extra metadata (bijv. task IDs, starter IDs)
  sentAt          DateTime         @default(now())

  @@index([type, sentAt])
  @@index([recipient, sentAt])
  @@index([recipientUserId])
  @@index([status])
}

// Document ondertekening
model StarterDocument {
  id            String         @id @default(cuid())
  starterId     String
  starter       Starter        @relation(fields: [starterId], references: [id], onDelete: Cascade)
  title         String // Document naam (bv. "Arbeidscontract")
  signingMethod SigningMethod  @default(SES)
  status        DocumentStatus @default(PENDING)

  // Teams/SharePoint opslag
  teamsDriveId      String? // SharePoint drive ID
  teamsItemId       String? // SharePoint item ID (origineel document)
  teamsPath         String? // Pad in Teams mappenstructuur
  signedTeamsItemId String? // SharePoint item ID (getekend document)
  signatureFields   Json? // [{page, x, y, width, height, label}] — posities van handtekeningvelden

  // Signing token voor publieke link
  signingToken String? @unique @default(cuid())

  // Ondertekening details
  signedAt     DateTime?
  signedByIp   String?
  signedByName String? // Naam van ondertekenaar

  // Itsme QES details (Phase 5B)
  itsmeSignatureId     String? // Itsme transactie ID
  itsmeCertificateInfo String? @db.Text // Certificaat informatie

  // Volgorde en afhankelijkheden
  sortOrder      Int               @default(0)
  prerequisiteId String? // Document dat eerst getekend moet worden
  prerequisite   StarterDocument?  @relation("DocumentChain", fields: [prerequisiteId], references: [id], onDelete: SetNull)
  dependents     StarterDocument[] @relation("DocumentChain")

  // Deadline
  dueDate DateTime?

  // Gekoppelde taak
  taskId String? @unique
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // Metadata
  fileName       String? // Originele bestandsnaam
  fileSize       Int? // Bestandsgrootte in bytes
  mimeType       String    @default("application/pdf")
  recipientEmail String? // E-mail van de ondertekenaar
  emailSentAt    DateTime? // Wanneer signing-link e-mail verstuurd is
  uploadedById   String? // User ID die document uploadde
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  auditEvents DocumentAuditEvent[]

  @@index([starterId, status])
  @@index([starterId, sortOrder])
  @@index([status])
  @@index([taskId])
}

// Document audit trail
model DocumentAuditEvent {
  id         String           @id @default(cuid())
  documentId String?
  document   StarterDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  event      String // CREATED, EMAIL_SENT, EMAIL_OPENED, EMAIL_CLICKED, EMAIL_DELIVERED, EMAIL_BOUNCED, VIEWED, SIGNED, DOWNLOADED, DELETED
  actor      String? // User ID, email, or "system"
  ip         String?
  userAgent  String?
  metadata   Json? // Extra data per event type
  createdAt  DateTime         @default(now())

  @@index([documentId, createdAt])
  @@index([event])
}

// Email Signature Templates per Entiteit
model SignatureTemplate {
  id           String   @id @default(cuid())
  entityId     String   @unique // Eén template per entiteit
  entity       Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  name         String // Naam van de template (bijv. "ACEG Standard")
  htmlTemplate String   @db.Text // De HTML template met placeholders
  isActive     Boolean  @default(true) // Of de template actief is
  createdBy    String // User ID die de template heeft aangemaakt
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityId])
  @@index([isActive])
}
